doctype html
html
  head
    meta(http-equiv='X-UA-Compatible', content='IE=edge')
    meta(charset='UTF-8')
    meta(name='viewport', content='user-scalable=yes, width=device-width, initial-scale=1, maximum-scale=5')
    meta(name='theme-color', content='#1976d2')
    meta(name='msapplication-TileColor', content='#1976d2')
    meta(name='msapplication-TileImage', content=siteConfig.assetBasePath + '/favicons/mstile-150x150.png')
    title Wiki.js Setup

    //- Favicon
    link(rel='apple-touch-icon', sizes='180x180', href=siteConfig.assetBasePath + '/favicons/apple-touch-icon.png')
    link(rel='icon', type='image/png', sizes='192x192', href=siteConfig.assetBasePath + '/favicons/android-chrome-192x192.png')
    link(rel='icon', type='image/png', sizes='32x32', href=siteConfig.assetBasePath + '/favicons/favicon-32x32.png')
    link(rel='icon', type='image/png', sizes='16x16', href=siteConfig.assetBasePath + '/favicons/favicon-16x16.png')
    link(rel='mask-icon', href=siteConfig.assetBasePath + '/favicons/safari-pinned-tab.svg', color='#1976d2')
    link(rel='manifest', href=siteConfig.assetBasePath + '/manifest.json')

    //- Site Lang
    script.
      var siteConfig = !{JSON.stringify(siteConfig)}

    //- Dev Mode Warning
    if devMode
      script.
        siteConfig.devMode = true

    //- CSS
    <% for (var index in htmlWebpackPlugin.files.css) { %>
    <% const cssPath = htmlWebpackPlugin.files.css[index].replace(/^.*\/_assets/, '') %>
    link(
      type='text/css'
      rel='stylesheet'
      href=siteConfig.assetBasePath + '<%= cssPath %>'
    )
    <% } %>

    //- JS
    <% for (var index in htmlWebpackPlugin.files.js) { %>
    <% const jsPath = htmlWebpackPlugin.files.js[index].replace(/^.*\/_assets/, '') %>
    script(
      type='text/javascript'
      src=siteConfig.assetBasePath + '<%= jsPath %>'
      )
    <% } %>

  body
    #root
      setup(telemetry-id=telemetryClientID, wiki-version=packageObj.version)
